# include <Servo.h>
Servo my;
int trigger = 11;
int echo = 10;
int led = 4;
int b = 7;

long time;
int distance;

void setup()
{
  Serial.begin(9600);

  pinMode(trigger, OUTPUT);
  pinMode(echo, INPUT);
  pinMode(led, OUTPUT);
  pinMode(b,OUTPUT);
  my.attach(4);
}

void loop()

{
  Serial.print(distance);
  digitalWrite(trigger, LOW);
  delayMicroseconds(2);

  digitalWrite(trigger, HIGH);
  delayMicroseconds(10);
digitalWrite(trigger, LOW);
  delayMicroseconds(2);

  digitalWrite(trigger, HIGH);
  delayMicroseconds(10);

  digitalWrite(trigger, LOW);

  time = pulseIn(echo, HIGH);
  digitalWrite(trigger, LOW);

  time = pulseIn(echo, HIGH);

  distance = time * 0.034 / 2;
  Serial.print("Distance: ");
  Serial.print(distance);
  Serial.println(" cm");
  
  if (distance <= 20)
  {
    
    digitalWrite(led, HIGH);
    digitalWrite(b,LOW);
    my.write(90);
  }
  else
  {
    digitalWrite(led, LOW);
    digitalWrite(b,HIGH);
    my.write(180);
  }

  delay(100);
}
